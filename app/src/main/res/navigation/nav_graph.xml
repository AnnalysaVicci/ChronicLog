<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Bottom Nav Destinations -->
    <!-- Home -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.anna.chroniclog.ui.HomeFragment"
        android:label="Home" >
        <action
            android:id="@+id/action_homeFragment_to_editHealthInformationFragment"
            app:destination="@+id/editHealthInformationFragment" />
    </fragment>

    <!-- Trends -->
    <fragment
        android:id="@+id/trendsFragment"
        android:name="com.anna.chroniclog.ui.TrendsFragment"
        android:label="Trends"
        tools:layout="@layout/fragment_trends" />

    <!-- Chat -->
    <fragment
        android:id="@+id/chatFragment"
        android:name="com.anna.chroniclog.ui.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat"/>


    <!-- Medications -->
    <fragment
        android:id="@+id/medicationsFragment"
        android:name="com.anna.chroniclog.ui.MedicationsFragment"
        android:label="Medications" >
        <action
            android:id="@+id/action_medicationsFragment_to_addMedicationFragment"
            app:destination="@+id/addMedicationFragment" />
    </fragment>

    <!-- Logs -->
    <fragment
        android:id="@+id/logsFragment"
        android:name="com.anna.chroniclog.ui.LogsFragment"
        android:label="Logs" >
        <action
            android:id="@+id/action_logsFragment_to_logFragment"
            app:destination="@+id/logFragment" />
        <action
            android:id="@+id/action_logsFragment_to_addLogFragment"
            app:destination="@+id/addLogFragment" />
    </fragment>

    <!-- Settings -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.anna.chroniclog.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <!-- Sub Screens -->
    <!-- Add Symptom -->
    <fragment
        android:id="@+id/addSymptomFragment"
        android:name="com.anna.chroniclog.ui.AddSymptomFragment"
        android:label="Add Symptom"
        tools:layout="@layout/fragment_add_symptom" />

    <!-- Add Medication -->
    <fragment
        android:id="@+id/addMedicationFragment"
        android:name="com.anna.chroniclog.ui.AddMedicationFragment"
        android:label="Add Medication"
        tools:layout="@layout/fragment_add_medication" />

    <!-- Add Remediation -->
    <fragment
        android:id="@+id/addRemediationFragment"
        android:name="com.anna.chroniclog.ui.AddRemediationFragment"
        android:label="Add Remediation"
        tools:layout="@layout/fragment_add_remediation" />

    <!-- Log -->
    <fragment
        android:id="@+id/logFragment"
        android:name="com.anna.chroniclog.ui.LogFragment"
        tools:layout="@layout/fragment_log">
        <argument
            android:name="logId"
            app:argType="string" />
        <action
            android:id="@+id/action_logFragment_to_EditLogFragment"
            app:destination="@+id/editLogFragment" />
    </fragment>

    <!-- Add Log -->
    <fragment
        android:id="@+id/addLogFragment"
        android:name="com.anna.chroniclog.ui.AddLogFragment"
        android:label="Add Log" >
        <action
            android:id="@+id/action_addLogFragment_to_addSymptomFragment"
            app:destination="@+id/addSymptomFragment" />
        <action
            android:id="@+id/action_addLogFragment_to_addRemediationFragment"
            app:destination="@+id/addRemediationFragment" />
        <action
            android:id="@+id/action_addLogFragment_to_logsFragment"
            app:destination="@+id/logsFragment" />
    </fragment>

    <!-- Edit Log -->
    <fragment
        android:id="@+id/editLogFragment"
        android:name="com.anna.chroniclog.ui.EditLogFragment"
        tools:layout="@layout/fragment_edit_log">
        <argument
            android:name="logId"
            app:argType="string" />
    </fragment>

    <!-- Edit Health Info -->
    <fragment
        android:id="@+id/editHealthInformationFragment"
        android:name="com.anna.chroniclog.ui.EditHealthInformationFragment"
        android:label="Edit Health info"
        tools:layout="@layout/fragment_edit_health_information" />

</navigation>