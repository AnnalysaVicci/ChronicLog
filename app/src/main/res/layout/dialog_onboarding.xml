<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:text="Welcome! Tell us a bit about yourself."
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- Add Age -->
    <TextView
        android:text="What is your age?"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <EditText
        android:id="@+id/etAge"
        android:inputType="number"
        android:hint="e.g. 28"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- Add Sex -->
    <TextView
        android:text="What is your sex?"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <Spinner
        android:id="@+id/spinnerSex"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <!-- Chronic Issues -->
    <TextView
        android:id="@+id/tvIssues"
        android:text="What chronic issues do you experience?"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />
    <AutoCompleteTextView
        android:id="@+id/atvIllness"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search common conditions..."
        android:completionThreshold="1"/>

    <Button
        android:id="@+id/btnAddIllness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add to Profile"
        android:layout_gravity="center"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgIllnesses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnSubmit"
        android:text="Get Started"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"/>

</LinearLayout>