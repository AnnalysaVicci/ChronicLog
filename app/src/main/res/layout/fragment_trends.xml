<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp"
    android:orientation="vertical">

    <!-- Trends TV-->
    <TextView
        android:id="@+id/tvTrends"
        android:text="Your Health Trends"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"/>

    <!-- Symptom Frequency Trends-->
    <TextView
        android:id="@+id/tvSymptomFreq"
        android:text="Symptom Frequency"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Outcome Trends-->
    <TextView
        android:id="@+id/tvRemediationOutcomes"
        android:text="Remediations and Outcomes"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Severity Over Time Trends-->
    <TextView
        android:id="@+id/tvSeverityTrend"
        android:text="Symptom Severity Over Time"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</LinearLayout>