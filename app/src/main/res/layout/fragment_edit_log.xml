<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp">

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:text="Date: "
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvEditDate"/>

        <TextView
            android:id="@+id/tvEditDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvDate"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Add Symptom -->
        <Button
            android:id="@+id/btnAddSymptom"
            android:text="+"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:padding="0dp"
            app:cornerRadius="0dp"
            app:layout_constraintEnd_toStartOf="@+id/tvAddSymptom"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEditDate" />
        <TextView
            android:id="@+id/tvAddSymptom"
            android:text="Add Symptom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            app:layout_constraintBaseline_toBaselineOf="@id/btnAddSymptom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/btnAddSymptom" />
        <!-- Symptom Recycler View-->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSymptoms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@+id/btnAddSymptom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Add Remediation -->
        <Button
            android:id="@+id/btnAddRemediation"
            android:text="+"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:padding="0dp"
            app:cornerRadius="0dp"
            app:layout_constraintStart_toStartOf="@id/btnAddSymptom"
            app:layout_constraintEnd_toEndOf="@id/btnAddSymptom"
            app:layout_constraintTop_toBottomOf="@id/rvSymptoms"/>
        <TextView
            android:id="@+id/tvAddRemediation"
            android:text="Add Remediation"
            android:paddingStart="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBaseline_toBaselineOf="@id/btnAddRemediation"
            app:layout_constraintStart_toEndOf="@id/btnAddRemediation" />
        <!-- Remediation Recycler View-->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRemediations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@+id/btnAddRemediation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Sentiment -->
        <TextView
            android:id="@+id/tvMood"
            android:text="Rate Your Day"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvRemediations" />
        <RadioGroup
            android:id="@+id/rgMood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvMood"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" >
            <RadioButton
                android:id="@+id/mood_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:button="@null"
                android:background="?attr/selectableItemBackground"
                android:drawableTop="@drawable/baseline_sentiment_very_dissatisfied_24"
                android:text="Terrible"
                android:gravity="center" />
            <RadioButton
                android:id="@+id/mood_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:button="@null"
                android:drawableTop="@drawable/baseline_sentiment_dissatisfied_24"
                android:text="Bad"
                android:gravity="center" />
            <RadioButton
                android:id="@+id/mood_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:button="@null"
                android:drawableTop="@drawable/baseline_sentiment_neutral_24"
                android:text="Meh"
                android:gravity="center" />
            <RadioButton
                android:id="@+id/mood_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:button="@null"
                android:drawableTop="@drawable/baseline_sentiment_satisfied_24"
                android:text="Good"
                android:gravity="center" />
            <RadioButton
                android:id="@+id/mood_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:button="@null"
                android:drawableTop="@drawable/baseline_sentiment_satisfied_alt_24"
                android:text="Amazing"
                android:gravity="center" />
        </RadioGroup>

        <!-- Notes -->
        <TextView
            android:id="@+id/tvNotes"
            android:text="Notes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="18sp"
            android:padding="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rgMood"/>
        <EditText
            android:id="@+id/etEditNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNotes"/>

        <!-- Add + Cancel Buttons -->
        <Button
            android:id="@+id/btnCancel"
            android:text="Cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/etEditNotes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnSave"/>
        <Button
            android:id="@+id/btnSave"
            android:text="Save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/etEditNotes"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btnCancel"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>